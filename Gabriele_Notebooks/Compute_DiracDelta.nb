          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"calI", "[", 
              RowBox[{"t", ",", "s"}], "]"}], 
             RowBox[{"funk", "[", 
              RowBox[{"t", ",", "s"}], "]"}]}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"s", "->", "0"}], ",", 
              RowBox[{"t", "->", 
               RowBox[{
                RowBox[{"-", "1"}], "+", 
                FractionBox[
                 RowBox[{"2", " ", "ks"}], "k"]}]}]}], "}"}]}], ")"}]}]}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"10", "^", 
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"-", "0.2"}], ",", "1.2", ",", ".005"}], "]"}]}]}], 
